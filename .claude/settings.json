{
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "FILE=$(cat - | jq -r '.tool_input.file_path') && case \"$FILE\" in */worker-configuration.d.ts) echo 'BLOCKED: auto-generated. Edit wrangler.jsonc then run pnpm cf-typegen.' >&2; exit 2;; */routeTree.gen.ts) echo 'BLOCKED: auto-generated by TanStack Router. Add/move route files instead.' >&2; exit 2;; esac"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "FILE=$(cat - | jq -r '.tool_input.file_path') && pnpm exec biome check --write --unsafe --skip=correctness/noUnusedImports \"$FILE\""
					}
				]
			}
		]
	},
	"enabledPlugins": {
		"ask@brainstormer": true,
		"blueprint@brainstormer": true,
		"carve@brainstormer": true,
		"dispatch@brainstormer": true,
		"lean@brainstormer": true,
		"tdd@brainstormer": true,
		"brainstorm@brainstormer": true
	},
	"extraKnownMarketplaces": {
		"brainstormer": {
			"source": {
				"source": "github",
				"repo": "auditmos/brainstormer"
			}
		}
	},
	"permissions": {
		"allow": [
			"Bash(tail:*)",
			"Bash(cat:*)",
			"Bash(grep:*)",
			"Bash(find:*)",
			"Bash(awk:*)",
			"Bash(ls:*)",
			"WebFetch(domain:tanstack.com/start/latest)",
			"WebFetch(domain:tanstack.com/router/latest)",
			"WebFetch(domain:tanstack.com/query/latest)",
			"WebFetch(domain:tanstack.com/form/latest)",
			"WebFetch(domain:ui.shadcn.com/docs)",
			"WebFetch(domain:hono.dev/docs/getting-started/cloudflare-workers)",
			"WebFetch(domain:hono.dev/docs/middleware/zod-validator)",
			"WebFetch(domain:pnpm.io/workspaces)",
			"WebFetch(domain:tailwindcss.com/docs/installation/using-vite)",
			"WebFetch(domain:vite.dev/guide/)",
			"WebFetch(domain:orm.drizzle.team/docs/overview)",
			"WebFetch(domain:react.dev/reference/react)",
			"WebFetch(domain:neon.com/docs/introduction)",
			"WebFetch(domain:developers.cloudflare.com/directory)",
			"WebFetch(domain:tweakcn.com)",
			"mcp__ide__getDiagnostics",
			"Bash(pnpm types:*)",
			"Bash(pnpm lint:*)",
			"Bash(pnpm view:*)"
		],
		"deny": ["Bash(rm -rf:*)", "Read(./.env)", "Read(./.env.*)"]
	}
}
